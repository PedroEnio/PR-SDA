if __name__ == "__main__":
    caminho = "C:\\Users\\PedroMedeiros\\OneDrive - Simm\\Documentos\\04 - PROJETOS\\102 - SOL DO AGRESTE\\00 - PR\\AnalogReport_20260714 - Sem Correntes (2).csv"
    
    # 1. Trata os dados (Traz GHI e IRRAD_POA juntos)
    dados_tratados = tratar_dados_ghi(caminho)
    
    # 2. Avalia se o dia foi válido
    eh_valido = validar_dia_poa(dados_tratados)
    
    print(f"\nResultado Final: O DIA É VÁLIDO? -> {eh_valido}\n")
    
    # 3. Plota o gráfico de GHI
    plotar_grafico_ghi(dados_tratados)

def _poa01(df, g, ufv):
    """POA isolado ("POA 01") da UFV — usado como reserva do GHI no gráfico.
    Prioriza a estação da UFV e o menor índice; sem POA -> série de NaN."""
    if not g["poa"]:
        return pd.Series(np.nan, index=df.index)
    num = NUM_POR_UFV.get(ufv)
    def _idx(tag):
        mm = re.search(r"WS[SR]_?\d+_?(\d+)", tag.upper())
        return int(mm.group(1)) if mm else 10**6
    cands = [c for c in g["poa"] if num is not None and re.search(rf"WS[SR]_?{num}", c.upper())] or g["poa"]
    col = min(cands, key=lambda c: (_idx(c), c))
    return df[col].astype(float)


def _pr_por_dia(df, g, ufv):
    """PR (%) por dia (Σ Eprod / Σ E_teórica no dia) p/ o gráfico de barras.
    Não filtra por validade — todos os dias entram (inspeção)."""
    coef = COEFICIENTE[TIPO_TESTE.upper()]; pdc = POWER_DC_KW[ufv]
    ener_full, _ = energia_intervalo(df, g, ufv)
    out = {}
    for dia, dfd in df.groupby(df.index.normalize()):
        poa = serie_media(dfd, g["poa"]); tm = serie_media(dfd, g["tmod"])
        ref = poa if REF_DIURNO == "poa" else serie_ghi(dfd, g, ufv)
        mask = (ref > IRRAD_MIN_DIURNO) & poa.notna() & tm.notna()
        idx = dfd.index[mask]
        if len(idx) == 0:
            continue
        tcel_ref = TCEL_REF[int(dia.month)][ufv]
        poa_w = poa[mask].astype(float)
        tcel = tm[mask].astype(float) + (poa_w/(G_STC*1000.0))*3.0
        a_s, ta = serie_albedo(dfd, g, ufv); alb = ALBEDO_REF_PCT
        if ta:
            a = a_s.reindex(idx).astype(float)
            if a.notna().any(): alb = float(a[a.notna()].mean())
        f_temp = 1.0 - (B_COEF*(tcel - tcel_ref))/100.0
        f_alb  = 1.0 + (alb - ALBEDO_REF_PCT)*coef
        if MODO_FORMULA == "verbatim":
            e_teo = FATOR_FORMULA * (poa_w*INTERVALO_H/1000.0 / G_STC) * pdc * f_temp * f_alb
        else:
            e_teo = (poa_w/(G_STC*1000.0))*pdc*INTERVALO_H*f_temp*f_alb
        eprod = ener_full.reindex(idx).fillna(0).astype(float)
        et = float(e_teo.sum())
        out[dia.date()] = (100.0*float(eprod.sum())/et if et else np.nan, bool(ta))
    return out



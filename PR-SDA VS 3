# 3) CÁLCULO DO PR (Seção 9)
# =============================================================================
def calcular_pr(df_val, g, ufv):
    """Calcula Eprod, E_teórica e PR por dia válido + PR do período.

    Por intervalo n:
      Tcel_n  = Tmod_n + (POA_n/G_STC) × 3
      f_temp  = 1 − B × (Tcel_n − Tcel_ref)/100
      f_alb   = 1 + (Albedo_med − 25) × Coeficiente   (Albedo_med = média % do
                sensor ABD no dia; sem sensor -> PR do dia INVÁLIDO, 3.5.15)
      E_teo_n = (POA_n/G_STC) × Power_DC × Δt × f_temp × f_alb    (modo "fisico")
      PR      = Σ Eprod_n / Σ E_teo_n   (só dias com sensor de albedo)
    """
    if df_val.empty:
        print("\n(nenhum dia válido — PR não calculado)")
        return pd.DataFrame(), None
    coef = COEFICIENTE[TIPO_TESTE.upper()]
    pdc = POWER_DC_KW[ufv]
    ener_full, fonte = energia_intervalo(df_val, g, ufv)
    print(f"\nFonte de energia (Eprod): {fonte}")
    print(f"UFV: {ufv} | Power_DC: {pdc} kW | Coef: {coef} | Fórmula: {MODO_FORMULA}")

    linhas = []
    for dia, dfd in df_val.groupby(df_val.index.normalize()):
        poa = serie_media(dfd, g["poa"])
        tmod = serie_media(dfd, g["tmod"])
        ref = poa if REF_DIURNO == "poa" else serie_media(dfd, g["ghi"])
        # só entram intervalos diurnos com POA e Tmod presentes
        mask = (ref > IRRAD_MIN_DIURNO) & poa.notna() & tmod.notna()
        d_idx = dfd.index[mask]
        if len(d_idx) == 0:
            continue
        mes = int(dia.month); tcel_ref = TCEL_REF[mes][ufv]   # Tabela 2 (mês × UFV)

        poa_w = poa[mask].astype(float)                       # W/m²
        poa_kwh = poa_w * INTERVALO_H / 1000.0                # kWh/m² no intervalo
        tcel_n = tmod[mask].astype(float) + (poa_w / (G_STC*1000.0)) * 3.0

        # Albedo (%) do sensor ABD da UFV (3.5.15): média dos intervalos COM
        # leitura. Sem sensor -> usa o valor-base só p/ exibir um número, mas o
        # PR do dia fica INVÁLIDO (não conta no PR do período).
        alb_serie, tem_alb = serie_albedo(dfd, g, ufv)
        if tem_alb:
            alb_dia = alb_serie.reindex(d_idx).astype(float)
            albedo_med = float(alb_dia[alb_dia.notna()].mean()) if alb_dia.notna().any() else np.nan
        else:
            albedo_med = np.nan
        alb_para_calculo = albedo_med if (tem_alb and pd.notna(albedo_med)) else ALBEDO_REF_PCT
        pr_valido = bool(tem_alb and pd.notna(albedo_med))

        f_temp = 1.0 - (B_COEF * (tcel_n - tcel_ref)) / 100.0
        f_alb  = 1.0 + (alb_para_calculo - ALBEDO_REF_PCT) * coef

        if MODO_FORMULA == "verbatim":
            # literal do documento: (POA em kWh/G_STC) × PowerDC × fatores
            e_teo = FATOR_FORMULA * (poa_kwh / G_STC) * pdc * f_temp * f_alb
        else:
            # "fisico": dimensionalmente consistente -> kW × h = kWh
            e_teo = (poa_w / (G_STC*1000.0)) * pdc * INTERVALO_H * f_temp * f_alb

        eprod = float(ener_full.reindex(d_idx).fillna(0).sum())
        e_teo_d = float(e_teo.sum())
        pr = eprod / e_teo_d if e_teo_d else np.nan
        status = "OK" if pr_valido else "INVÁLIDO (sem sensor albedo — 3.5.15)"
        linhas.append({"dia": dia.date(), "intervalos": int(mask.sum()),
                       "Eprod_kWh": round(eprod,2), "E_teorica_kWh": round(e_teo_d,2),
                       "Tcel_ref_C": tcel_ref,
                       "Albedo_med_pct": round(albedo_med,2) if pd.notna(albedo_med) else np.nan,
                       "PR_dia_%": round(pr*100,2), "PR_status": status})

    df_pr = pd.DataFrame(linhas)
    pr_per = None
    if not df_pr.empty:
        ok = df_pr["PR_status"] == "OK"
        n_inval = int((~ok).sum())
        if n_inval:
            print(f"⚠️  {n_inval} dia(s) sem sensor de albedo (ABD): PR do dia INVÁLIDO "
                  f"(3.5.15) — usa valor-base {ALBEDO_REF_PCT:.0f}% só p/ exibir e "
                  f"NÃO entra no PR do período.")
        print("\n=== RESULTADO PR ===")
        print(df_pr.to_string(index=False))
        df_ok = df_pr[ok]
        if df_ok.empty:
            print("\n(nenhum dia com sensor de albedo — PR do período não calculado)")
            return df_pr, None
        if df_ok["Eprod_kWh"].sum() == 0:
            print("⚠️  Eprod total = 0: sem fonte de energia (PMI/POT ausentes e inversor "
                  "excluído). O PR sai 0% — não reflete a usina. Habilite uma fonte de energia.")
        # PR do período = razão das SOMAS dos dias VÁLIDOS (não é média dos PRs)
        pr_per = df_ok["Eprod_kWh"].sum()/df_ok["E_teorica_kWh"].sum()
        print(f"\nDias no cálculo: {len(df_ok)} | PR do período: {pr_per*100:.2f} %")
    return df_pr, pr_per


